<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <!-- ═══════════════════════════════════════════════════
    记忆检索压测计划
    端点: POST /api/v1/memory/search
    验收: P90 ≤ 500ms, 10万条记忆库

    使用方法:
      1. 修改"用户自定义变量"中的 base_url, query_csv 路径
      2. jmeter -n -t tests/benchmark_search.jmx -l results.jtl
      3. 用 benchmark_report.py 分析结果

    或 GUI 模式:
      jmeter -t tests/benchmark_search.jmx
    ═══════════════════════════════════════════════════ -->
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="记忆检索压测计划" enabled="true">
      <stringProp name="TestPlan.comments">10万记忆库 P90≤500ms 验收</stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.tearDown_on_shutdown">true</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="用户自定义变量" enabled="true">
        <collectionProp name="Arguments.arguments">
          <elementProp name="BASE_URL" elementType="Argument">
            <stringProp name="Argument.name">BASE_URL</stringProp>
            <stringProp name="Argument.value">localhost:8000</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="DURATION" elementType="Argument">
            <stringProp name="Argument.name">DURATION</stringProp>
            <stringProp name="Argument.value">60</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">每线程组持续时间(秒)</stringProp>
          </elementProp>
          <elementProp name="WARMUP" elementType="Argument">
            <stringProp name="Argument.name">WARMUP</stringProp>
            <stringProp name="Argument.value">10</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">预热时间(秒)</stringProp>
          </elementProp>
        </collectionProp>
      </elementProp>
    </TestPlan>
    <hashTree>
      <!-- ═══════════════════════════════════════════════════
      线程组 1: 预热 (5并发, 短时间)
      ═══════════════════════════════════════════════════ -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="预热-5并发" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="循环控制器" enabled="true">
          <boolProp name="LoopController.continue_forever">true</boolProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">5</stringProp>
        <stringProp name="ThreadGroup.ramp_time">2</stringProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.duration">${__P(warmup_duration, ${WARMUP})}</stringProp>
        <stringProp name="ThreadGroup.delay">0</stringProp>
      </ThreadGroup>
      <hashTree>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="检索-纯语义" enabled="true">
          <stringProp name="HTTPSampler.domain">${BASE_URL}</stringProp>
          <stringProp name="HTTPSampler.port"></stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
          <stringProp name="HTTPSampler.path">/api/v1/memory/search</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="用户自定义变量" enabled="true">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP请求头" enabled="true">
            <collectionProp name="HeaderManager.headers">
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">Content-Type</stringProp>
                <stringProp name="Header.value">application/json</stringProp>
              </elementProp>
            </collectionProp>
          </HeaderManager>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="生成随机请求体" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
// 随机查询池 (200条真实对话)
String[] queries = [
  "Python装饰器的实现原理是什么",
  "如何在React中管理全局状态",
  "帮我写一个排序算法",
  "我们上次讨论的项目截止日期是几号",
  "我不喜欢太复杂的界面设计",
  "CRISPR基因编辑技术的最新进展",
  "这个游戏的通关攻略",
  "我们的OKR目标完成情况如何",
  "MySQL和PostgreSQL的区别",
  "请用通俗的语言解释机器学习",
  "你觉得这个方案可行吗",
  "我之前提到过的那个需求还在排期中吗",
  "能不能给我一个简单的例子",
  "法律上这个条款怎么理解",
  "有没有推荐的钢琴练习曲",
  "我习惯用VSCode而不是Vim",
  "上次会议决定用哪个框架了",
  "帮我优化这段SQL查询",
  "前端路由和状态管理的关系",
  "为什么要使用Docker容器化",
  "微服务和单体架构的优劣对比",
  "NFT市场目前的发展趋势",
  "我倾向于先做MVP再迭代",
  "Git merge和rebase的区别",
  "协程和线程哪个更适合IO密集型",
  "我想学一门新语言，推荐Go还是Rust",
  "这段代码的内存泄漏怎么排查",
  "分布式事务的一致性保证",
  "记得我们讨论过要用异步方案",
  "你对这个UI配色有什么建议"
];
String[] userIds = [];
for (int i = 0; i &lt; 100; i++) {
  userIds.add(String.format("bench_user_%03d", i));
}
String[] sceneIds = ["scene_code","scene_chat","scene_game","scene_biz","scene_science","scene_music","scene_health","scene_finance","scene_education","scene_design"];
String[] taskIds = ["task_create","task_qa","task_iterate","task_review","task_debug"];
String[] memTypes = ["preference","fact","task","decision","constraint"];

Random rand = new Random();
String query = queries[rand.nextInt(queries.length)];
String userId = userIds[rand.nextInt(userIds.length)];

// 构建请求体
def body = [:]
body.query = query
body.user_id = userId
body.top_k = 10
body.rerank = true
body.include_scores = true

// 随机加过滤条件 (30%概率)
if (rand.nextFloat() &lt; 0.3) {
  body.scene_id = sceneIds[rand.nextInt(sceneIds.length)];
}
if (rand.nextFloat() &lt; 0.2) {
  body.task_id = taskIds[rand.nextInt(taskIds.length)];
}
if (rand.nextFloat() &lt; 0.15) {
  body.memory_types = [memTypes[rand.nextInt(memTypes.length)]];
}

import groovy.json.JsonOutput;
sampler.addNonEncodedArgument("", JsonOutput.toJson(body), "");
sampler.setPostBodyRaw(true);
            </stringProp>
          </JSR223PreProcessor>
        </hashTree>
      </hashTree>

      <!-- ═══════════════════════════════════════════════════
      线程组 2: 低并发 (10并发)
      ═══════════════════════════════════════════════════ -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="压测-10并发" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="循环控制器" enabled="true">
          <boolProp name="LoopController.continue_forever">true</boolProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">10</stringProp>
        <stringProp name="ThreadGroup.ramp_time">3</stringProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.duration">${DURATION}</stringProp>
        <stringProp name="ThreadGroup.delay">${WARMUP}</stringProp>
      </ThreadGroup>
      <hashTree>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="检索" enabled="true">
          <stringProp name="HTTPSampler.domain">${BASE_URL}</stringProp>
          <stringProp name="HTTPSampler.path">/api/v1/memory/search</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP请求头" enabled="true">
            <collectionProp name="HeaderManager.headers">
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">Content-Type</stringProp>
                <stringProp name="Header.value">application/json</stringProp>
              </elementProp>
            </collectionProp>
          </HeaderManager>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="生成随机请求体" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
// (同上的随机查询逻辑 — 可抽取为外部 groovy 文件)
String[] queries = [
  "Python装饰器的实现原理是什么","如何在React中管理全局状态","帮我写一个排序算法",
  "我们上次讨论的项目截止日期是几号","我不喜欢太复杂的界面设计","CRISPR基因编辑技术的最新进展",
  "这个游戏的通关攻略","我们的OKR目标完成情况如何","MySQL和PostgreSQL的区别",
  "请用通俗的语言解释机器学习","你觉得这个方案可行吗","我之前提到过的那个需求还在排期中吗",
  "能不能给我一个简单的例子","法律上这个条款怎么理解","有没有推荐的钢琴练习曲",
  "我习惯用VSCode而不是Vim","上次会议决定用哪个框架了","帮我优化这段SQL查询",
  "为什么要使用Docker容器化","微服务和单体架构的优劣对比","NFT市场目前的发展趋势",
  "我倾向于先做MVP再迭代","Git merge和rebase的区别","协程和线程哪个更适合IO密集型",
  "我想学一门新语言，推荐Go还是Rust","这段代码的内存泄漏怎么排查","分布式事务的一致性保证",
  "记得我们讨论过要用异步方案","你对这个UI配色有什么建议"
];
String[] sceneIds = ["scene_code","scene_chat","scene_game","scene_biz","scene_science","scene_music","scene_health","scene_finance","scene_education","scene_design"];
String[] taskIds = ["task_create","task_qa","task_iterate","task_review","task_debug"];
String[] memTypes = ["preference","fact","task","decision","constraint"];

Random rand = new Random();

def body = [:]
body.query = queries[rand.nextInt(queries.length)]
body.user_id = String.format("bench_user_%03d", rand.nextInt(100))
body.top_k = 10
body.rerank = true
body.include_scores = true

if (rand.nextFloat() &lt; 0.3) body.scene_id = sceneIds[rand.nextInt(sceneIds.length)]
if (rand.nextFloat() &lt; 0.2) body.task_id = taskIds[rand.nextInt(taskIds.length)]
if (rand.nextFloat() &lt; 0.15) body.memory_types = [memTypes[rand.nextInt(memTypes.length)]]

import groovy.json.JsonOutput;
sampler.addNonEncodedArgument("", JsonOutput.toJson(body), "");
sampler.setPostBodyRaw(true);
            </stringProp>
          </JSR223PreProcessor>
        </hashTree>
      </hashTree>

      <!-- ═══════════════════════════════════════════════════
      线程组 3: 中并发 (20并发)
      ═══════════════════════════════════════════════════ -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="压测-20并发" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="循环控制器" enabled="true">
          <boolProp name="LoopController.continue_forever">true</boolProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">20</stringProp>
        <stringProp name="ThreadGroup.ramp_time">5</stringProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.duration">${DURATION}</stringProp>
        <stringProp name="ThreadGroup.delay">${__groovy(${WARMUP} + ${DURATION} as int)}</stringProp>
      </ThreadGroup>
      <hashTree>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="检索" enabled="true">
          <stringProp name="HTTPSampler.domain">${BASE_URL}</stringProp>
          <stringProp name="HTTPSampler.path">/api/v1/memory/search</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP请求头" enabled="true">
            <collectionProp name="HeaderManager.headers">
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">Content-Type</stringProp>
                <stringProp name="Header.value">application/json</stringProp>
              </elementProp>
            </collectionProp>
          </HeaderManager>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="生成随机请求体" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
String[] queries = ["Python装饰器的实现原理是什么","如何在React中管理全局状态","帮我写一个排序算法","我们上次讨论的项目截止日期是几号","我不喜欢太复杂的界面设计","CRISPR基因编辑技术的最新进展","这个游戏的通关攻略","我们的OKR目标完成情况如何","MySQL和PostgreSQL的区别","请用通俗的语言解释机器学习","你觉得这个方案可行吗","我之前提到过的那个需求还在排期中吗","能不能给我一个简单的例子","法律上这个条款怎么理解","有没有推荐的钢琴练习曲","我习惯用VSCode而不是Vim","上次会议决定用哪个框架了","帮我优化这段SQL查询","为什么要使用Docker容器化","微服务和单体架构的优劣对比","NFT市场目前的发展趋势","我倾向于先做MVP再迭代","Git merge和rebase的区别","协程和线程哪个更适合IO密集型","我想学一门新语言，推荐Go还是Rust","这段代码的内存泄漏怎么排查","分布式事务的一致性保证","记得我们讨论过要用异步方案","你对这个UI配色有什么建议"];
String[] sceneIds = ["scene_code","scene_chat","scene_game","scene_biz","scene_science","scene_music","scene_health","scene_finance","scene_education","scene_design"];
String[] taskIds = ["task_create","task_qa","task_iterate","task_review","task_debug"];
String[] memTypes = ["preference","fact","task","decision","constraint"];
Random rand = new Random();
def body = [:];
body.query = queries[rand.nextInt(queries.length)];
body.user_id = String.format("bench_user_%03d", rand.nextInt(100));
body.top_k = 10;
body.rerank = true;
body.include_scores = true;
if (rand.nextFloat() &lt; 0.3) body.scene_id = sceneIds[rand.nextInt(sceneIds.length)];
if (rand.nextFloat() &lt; 0.2) body.task_id = taskIds[rand.nextInt(taskIds.length)];
if (rand.nextFloat() &lt; 0.15) body.memory_types = [memTypes[rand.nextInt(memTypes.length)]];
import groovy.json.JsonOutput;
sampler.addNonEncodedArgument("", JsonOutput.toJson(body), "");
sampler.setPostBodyRaw(true);
            </stringProp>
          </JSR223PreProcessor>
        </hashTree>
      </hashTree>

      <!-- ═══════════════════════════════════════════════════
      线程组 4: 高并发 (50并发)
      ═══════════════════════════════════════════════════ -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="压测-50并发" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="循环控制器" enabled="true">
          <boolProp name="LoopController.continue_forever">true</boolProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">50</stringProp>
        <stringProp name="ThreadGroup.ramp_time">10</stringProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.duration">${DURATION}</stringProp>
        <stringProp name="ThreadGroup.delay">${__groovy((${WARMUP} + ${DURATION}) * 2 as int)}</stringProp>
      </ThreadGroup>
      <hashTree>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="检索" enabled="true">
          <stringProp name="HTTPSampler.domain">${BASE_URL}</stringProp>
          <stringProp name="HTTPSampler.path">/api/v1/memory/search</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP请求头" enabled="true">
            <collectionProp name="HeaderManager.headers">
              <elementProp name="" elementType="Header">
                <stringProp name="Header.name">Content-Type</stringProp>
                <stringProp name="Header.value">application/json</stringProp>
              </elementProp>
            </collectionProp>
          </HeaderManager>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="生成随机请求体" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
String[] queries = ["Python装饰器的实现原理是什么","如何在React中管理全局状态","帮我写一个排序算法","我们上次讨论的项目截止日期是几号","我不喜欢太复杂的界面设计","CRISPR基因编辑技术的最新进展","这个游戏的通关攻略","我们的OKR目标完成情况如何","MySQL和PostgreSQL的区别","请用通俗的语言解释机器学习","你觉得这个方案可行吗","我之前提到过的那个需求还在排期中吗","能不能给我一个简单的例子","法律上这个条款怎么理解","有没有推荐的钢琴练习曲","我习惯用VSCode而不是Vim","上次会议决定用哪个框架了","帮我优化这段SQL查询","为什么要使用Docker容器化","微服务和单体架构的优劣对比","NFT市场目前的发展趋势","我倾向于先做MVP再迭代","Git merge和rebase的区别","协程和线程哪个更适合IO密集型","我想学一门新语言，推荐Go还是Rust","这段代码的内存泄漏怎么排查","分布式事务的一致性保证","记得我们讨论过要用异步方案","你对这个UI配色有什么建议"];
String[] sceneIds = ["scene_code","scene_chat","scene_game","scene_biz","scene_science","scene_music","scene_health","scene_finance","scene_education","scene_design"];
String[] taskIds = ["task_create","task_qa","task_iterate","task_review","task_debug"];
String[] memTypes = ["preference","fact","task","decision","constraint"];
Random rand = new Random();
def body = [:];
body.query = queries[rand.nextInt(queries.length)];
body.user_id = String.format("bench_user_%03d", rand.nextInt(100));
body.top_k = 10;
body.rerank = true;
body.include_scores = true;
if (rand.nextFloat() &lt; 0.3) body.scene_id = sceneIds[rand.nextInt(sceneIds.length)];
if (rand.nextFloat() &lt; 0.2) body.task_id = taskIds[rand.nextInt(taskIds.length)];
if (rand.nextFloat() &lt; 0.15) body.memory_types = [memTypes[rand.nextInt(memTypes.length)]];
import groovy.json.JsonOutput;
sampler.addNonEncodedArgument("", JsonOutput.toJson(body), "");
sampler.setPostBodyRaw(true);
            </stringProp>
          </JSR223PreProcessor>
        </hashTree>
      </hashTree>

      <!-- ═══════════════════════════════════════════════════
      监听器
      ═══════════════════════════════════════════════════ -->
      <ResultCollector guiclass="SummaryReport" testclass="ResultCollector" testname="汇总报告" enabled="true">
        <boolProp name="ResultCollector.error_logging">false</boolProp>
        <objProp>
          <name>saveConfig</name>
          <value class="SampleSaveConfiguration">
            <time>true</time>
            <latency>true</latency>
            <timestamp>true</timestamp>
            <success>true</success>
            <label>true</label>
            <code>true</code>
            <message>true</message>
            <threadName>true</threadName>
            <dataType>true</dataType>
            <encoding>false</encoding>
            <assertions>true</assertions>
            <subresults>true</subresults>
            <responseData>false</responseData>
            <samplerData>false</samplerData>
            <xml>false</xml>
            <fieldNames>true</fieldNames>
            <responseHeaders>false</responseHeaders>
            <requestHeaders>false</requestHeaders>
            <responseDataOnError>false</responseDataOnError>
            <saveAssertionResultsFailureMessage>true</saveAssertionResultsFailureMessage>
            <assertionsResultsToSave>0</assertionsResultsToSave>
            <bytes>true</bytes>
            <sentBytes>true</sentBytes>
            <url>true</url>
            <threadCounts>true</threadCounts>
            <idleTime>true</idleTime>
            <connectTime>true</connectTime>
          </value>
        </objProp>
        <stringProp name="filename">benchmark_results.jtl</stringProp>
      </ResultCollector>
      <hashTree/>

      <ResultCollector guiclass="ViewResultsFullVisualizer" testclass="ResultCollector" testname="结果树" enabled="false">
        <boolProp name="ResultCollector.error_logging">false</boolProp>
        <stringProp name="filename"></stringProp>
      </ResultCollector>
      <hashTree/>

    </hashTree>
  </hashTree>
</jmeterTestPlan>
